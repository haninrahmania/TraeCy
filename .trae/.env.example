# Alignment MCP Server Configuration
# Copy this file to .env and configure as needed

# Scoring backend: "embeddings" (default) or "tfidf"
# - embeddings: Uses sentence-transformers (requires download, more accurate)
# - tfidf: Uses TF-IDF cosine similarity (offline, faster, lexical only)
ALIGNMENT_BACKEND=embeddings

# Optional: Custom threshold for supporting deliverables
# ALIGNMENT_THRESHOLD=0.40
